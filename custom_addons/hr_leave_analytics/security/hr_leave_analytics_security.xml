<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_analytics_report_rule_company" model="ir.rule">
        <field name="name">HR Leave Analytics: multi-company</field>
        <field name="model_id" ref="model_hr_leave_analytics_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="hr_leave_analytics_store_summary_rule_company" model="ir.rule">
        <field name="name">HR Leave Store Summary: multi-company</field>
        <field name="model_id" ref="model_hr_leave_analytics_store_summary"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="hr_leave_analytics_mien_summary_rule_company" model="ir.rule">
        <field name="name">HR Leave Mien Summary: multi-company</field>
        <field name="model_id" ref="model_hr_leave_analytics_mien_summary"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="hr_leave_analytics_employee_watch_rule_company" model="ir.rule">
        <field name="name">HR Leave Employee Watch: multi-company</field>
        <field name="model_id" ref="model_hr_leave_analytics_employee_watch"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="hr_leave_analytics_mien_summary_rule_mien" model="ir.rule">
        <field name="name">HR Leave Analytics: theo miền được phép</field>
        <field name="model_id" ref="model_hr_leave_analytics_mien_summary"/>
        <field name="domain_force">[(1, '=', 1)] if user.hr_leave_analytics_allowed_miens is None else [('employee_mien', 'in', user.hr_leave_analytics_allowed_miens or [''])]</field>
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_user'))]"/>
    </record>

    <record id="hr_leave_analytics_store_summary_rule_mien" model="ir.rule">
        <field name="name">HR Leave Store Summary: theo miền được phép</field>
        <field name="model_id" ref="model_hr_leave_analytics_store_summary"/>
        <field name="domain_force">[(1, '=', 1)] if user.hr_leave_analytics_allowed_miens is None else [('employee_mien', 'in', user.hr_leave_analytics_allowed_miens or [''])]</field>
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_user'))]"/>
    </record>

    <record id="hr_leave_analytics_employee_watch_rule_mien" model="ir.rule">
        <field name="name">HR Leave Employee Watch: theo miền được phép</field>
        <field name="model_id" ref="model_hr_leave_analytics_employee_watch"/>
        <field name="domain_force">[(1, '=', 1)] if user.hr_leave_analytics_allowed_miens is None else [('employee_mien', 'in', user.hr_leave_analytics_allowed_miens or [''])]</field>
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_user'))]"/>
    </record>

    <record id="hr_leave_analytics_report_rule_mien" model="ir.rule">
        <field name="name">HR Leave Analytics Report: theo miền được phép</field>
        <field name="model_id" ref="model_hr_leave_analytics_report"/>
        <field name="domain_force">[(1, '=', 1)] if user.hr_leave_analytics_allowed_miens is None else ['|', ('employee_mien', 'in', user.hr_leave_analytics_allowed_miens or ['']), ('employee_mien', '=', False)]</field>
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_user'))]"/>
    </record>
</odoo>
