<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record model="res.groups.privilege" id="res_groups_privilege_checklist">
            <field name="name">Employee Checklist</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>

        <record id="group_checklist_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_checklist"/>
        </record>

        <record id="group_checklist_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="sequence">20</field>
            <field name="implied_ids" eval="[(4, ref('group_checklist_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_checklist"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>

    <data noupdate="1">
        <record model="ir.rule" id="checklist_checklist_company_rule">
            <field name="name">Checklist: multi-company</field>
            <field name="model_id" ref="model_checklist_checklist"/>
            <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
        </record>
        <record model="ir.rule" id="checklist_registration_company_rule">
            <field name="name">Checklist/Registration: multi-company</field>
            <field name="model_id" ref="model_checklist_registration"/>
            <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
        </record>
    </data>
</odoo>
