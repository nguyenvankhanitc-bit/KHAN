#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
msgid "Only users with Attendance Officer role or administrators can do second approval."
msgstr "Chỉ người dùng có vai trò Officer trong Chấm công hoặc quản trị viên mới có thể duyệt cấp 2."

#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
msgid "Only tickets in second approval state can be approved."
msgstr "Chỉ phiếu ở trạng thái duyệt cấp 2 mới có thể duyệt."

#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
msgid "Only the assigned second approver or administrators can do second approval."
msgstr "Chỉ người duyệt cấp 2 được chỉ định hoặc quản trị viên mới có thể duyệt cấp 2."

#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
msgid "Only draft tickets can be submitted."
msgstr "Chỉ phiếu ở trạng thái nháp mới có thể gửi."

#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
msgid "Only tickets in first approval or refused state can be approved."
msgstr "Chỉ phiếu ở trạng thái duyệt cấp 1 hoặc đã từ chối mới có thể duyệt."

#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
msgid "Only the assigned first approver or administrators can do first approval."
msgstr "Chỉ người duyệt cấp 1 được chỉ định hoặc quản trị viên mới có thể duyệt cấp 1."

#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
msgid "Only confirmed, second approval, or approved tickets can be refused."
msgstr "Chỉ phiếu đã xác nhận, duyệt cấp 2 hoặc đã duyệt mới có thể từ chối."

#. module: hr_employee_gate_ticket
#: code:addons/hr_employee_gate_ticket/models/hr_employee_gate_ticket.py:0
