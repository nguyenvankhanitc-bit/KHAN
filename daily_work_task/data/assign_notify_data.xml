<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Bot Discuss riêng cho module — không dùng / không sửa OdooBot Duyệt đơn -->
        <record id="partner_bot_assign_task" model="res.partner">
            <field name="name">OdooBot Giao việc</field>
            <field name="email">odoo.bot.assign.task@localhost</field>
            <field name="company_type">person</field>
            <field name="active" eval="True"/>
        </record>

        <record id="user_bot_assign_task" model="res.users">
            <field name="name">OdooBot Giao việc</field>
            <field name="login">odoo.bot.assign.task</field>
            <field name="partner_id" ref="partner_bot_assign_task"/>
            <field name="group_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
            <field name="notification_type">inbox</field>
            <field name="active" eval="True"/>
        </record>

        <record id="mail_act_daily_task_assigned" model="mail.activity.type">
            <field name="name">Công việc được giao</field>
            <field name="icon">fa-tasks</field>
            <field name="res_model">daily.task</field>
            <field name="delay_count">0</field>
            <field name="summary">Bạn có công việc mới được giao</field>
        </record>
    </data>
</odoo>
