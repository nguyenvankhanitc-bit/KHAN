<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List -->
    <record id="view_daily_task_list" model="ir.ui.view">
        <field name="name">daily.task.list</field>
        <field name="model">daily.task</field>
        <field name="arch" type="xml">
            <list string="Danh sách công việc" decoration-success="state == 'done'"
                  decoration-info="state == 'in_progress'" decoration-muted="state == 'not_started'"
                  decoration-danger="is_overdue">
                <field name="name"/>
                <field name="assign_date" string="Ngày giao" optional="show"/>
                <field name="assigned_by_id" string="Người giao" optional="show"/>
                <field name="deadline"/>
                <field name="department_id" optional="hide"/>
                <field name="work_group_id" optional="show"/>
                <field name="assignee_id"/>
                <field name="priority" widget="badge"
                         decoration-danger="priority == 'high'"
                         decoration-warning="priority == 'medium'"
                         decoration-muted="priority == 'low'"/>
                <field name="duration_minutes" string="Phút" optional="show"/>
                <field name="duration_hours" string="Giờ" optional="show" sum="Tổng giờ"/>
                <field name="completion_percent" string="% Hoàn thành CV" optional="show"/>
                <field name="state" widget="badge"
                         decoration-success="state == 'done'"
                         decoration-info="state == 'in_progress'"
                         decoration-muted="state == 'not_started'"/>
                <field name="is_overdue" optional="show"/>
                <field name="note" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_daily_task_form" model="ir.ui.view">
        <field name="name">daily.task.form</field>
        <field name="model">daily.task</field>
        <field name="arch" type="xml">
            <form string="Công việc">
                <header>
                    <button name="action_set_not_started" type="object" string="Chưa bắt đầu"
                            invisible="state == 'not_started'" class="btn-secondary"/>
                    <button name="action_set_in_progress" type="object" string="Đang xử lý"
                            invisible="state == 'in_progress'" class="btn-primary"/>
                    <button name="action_set_done" type="object" string="Hoàn thành"
                            invisible="state == 'done'" class="btn-success"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="not_started,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên công việc"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="assign_date"/>
                            <field name="assigned_by_id"/>
                            <field name="deadline"/>
                            <field name="department_id"/>
                            <field name="work_group_id"/>
                            <field name="assignee_id"/>
                            <field name="employee_hr_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="duration_minutes"/>
                            <field name="duration_hours" readonly="1"/>
                            <field name="completion_percent"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                    </group>
                    <group string="Ghi chú bổ sung">
                        <field name="note" nolabel="1" placeholder="Nhập mô tả chi tiết"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban by state -->
    <record id="view_daily_task_kanban" model="ir.ui.view">
        <field name="name">daily.task.kanban</field>
        <field name="model">daily.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" quick_create="false">
                <field name="name"/>
                <field name="deadline"/>
                <field name="assignee_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="color"/>
                <field name="is_overdue"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="deadline"/> — <field name="assignee_id"/>
                            </div>
                            <div>
                                <field name="priority" widget="badge"
                                         decoration-danger="priority == 'high'"
                                         decoration-warning="priority == 'medium'"
                                         decoration-muted="priority == 'low'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Calendar -->
    <record id="view_daily_task_calendar" model="ir.ui.view">
        <field name="name">daily.task.calendar</field>
        <field name="model">daily.task</field>
        <field name="arch" type="xml">
            <calendar string="Calendar To Do List" date_start="deadline" color="color"
                      mode="month" quick_create="0" event_open_popup="1">
                <field name="name"/>
                <field name="assignee_id"/>
                <field name="priority"/>
                <field name="state" filters="1"/>
                <field name="department_id"/>
                <field name="color"/>
            </calendar>
        </field>
    </record>

    <!-- Search -->
    <record id="view_daily_task_search" model="ir.ui.view">
        <field name="name">daily.task.search</field>
        <field name="model">daily.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="assignee_id"/>
                <field name="department_id"/>
                <filter string="Hoàn thành" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Đang xử lý" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Chưa bắt đầu" name="filter_not_started" domain="[('state', '=', 'not_started')]"/>
                <separator/>
                <filter string="Quá hạn" name="filter_overdue" domain="[('is_overdue', '=', True)]"/>
                <filter string="Ưu tiên cao" name="filter_high" domain="[('priority', '=', 'high')]"/>
                <group>
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Người phụ trách" name="group_assignee" context="{'group_by': 'assignee_id'}"/>
                    <filter string="Bộ phận" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Ưu tiên" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Hạn" name="group_deadline" context="{'group_by': 'deadline'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_daily_task" model="ir.actions.act_window">
        <field name="name">Quản lý dữ liệu công việc</field>
        <field name="res_model">daily.task</field>
        <field name="view_mode">list,kanban,form,calendar</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Thêm công việc mới</p>
            <p>Nhập tên, hạn, bộ phận, người phụ trách, ưu tiên và trạng thái.</p>
        </field>
    </record>

    <record id="action_daily_task_employee_workspace" model="ir.actions.act_window">
        <field name="name">Nhân viên nhập CV</field>
        <field name="res_model">daily.task</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_assignee': 1}</field>
        <field name="help" type="html">
            <p>Chọn / lọc theo người phụ trách để xem việc được giao.</p>
        </field>
    </record>

    <record id="action_daily_task_calendar" model="ir.actions.act_window">
        <field name="name">Calendar To Do List</field>
        <field name="res_model">daily.task</field>
        <field name="view_mode">calendar,list,form</field>
    </record>

    <record id="action_daily_task_overdue" model="ir.actions.act_window">
        <field name="name">Việc quá hạn</field>
        <field name="res_model">daily.task</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_overdue', '=', True)]</field>
        <field name="context">{'search_default_filter_overdue': 1}</field>
    </record>
</odoo>
