<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lug_user_permission_list" model="ir.ui.view">
        <field name="name">lug.user.permission.list</field>
        <field name="model">lug.user.permission</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="app_id" options="{'no_create': True}"/>
                <field name="perm_view"/>
                <field name="perm_create"/>
                <field name="perm_edit"/>
                <field name="perm_delete"/>
                <field name="perm_approve"/>
                <field name="perm_export"/>
                <field name="perm_import"/>
                <field name="perm_print"/>
            </list>
        </field>
    </record>

    <record id="view_users_form_lug_permission" model="ir.ui.view">
        <field name="name">res.users.form.lug.permission</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="LUG Permission" name="lug_permission">
                    <group>
                        <group string="Nhóm quyền">
                            <field name="lug_group_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Phạm vi dữ liệu (Data Scope)">
                            <field name="lug_data_scope" widget="radio"/>
                            <div class="text-muted" colspan="2">
                                Tự đồng bộ sang tab <b>Phạm vi xem nhân viên</b>
                                (visibility_policy). User không dùng LUG vẫn cấu hình
                                phạm vi ở tab đó như cũ.
                            </div>
                        </group>
                    </group>
                    <group string="Mã bộ phận được xem (STORE)"
                           invisible="lug_data_scope != 'store'">
                        <field name="assigned_ma_bo_phan_ids" nolabel="1"
                               widget="many2many_tags"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                        <div class="text-muted" colspan="2">
                            Chọn nhiều mã bộ phận khi ASM quản nhiều cửa hàng.
                            Để trống = chỉ xem cùng mã bộ phận với nhân viên của user.
                        </div>
                    </group>
                    <group string="Thông tin tổ chức (chỉ đọc)">
                        <field name="employee_ma_bo_phan_id" readonly="1"/>
                        <field name="employee_department_id" readonly="1"/>
                        <field name="employee_mien" readonly="1"/>
                        <field name="visibility_policy" readonly="1"
                               string="Phạm vi xem (đồng bộ)"/>
                    </group>
                    <separator string="Quyền sửa hồ sơ nhân viên"/>
                    <group>
                        <field name="lug_hr_employee_edit_policy" widget="radio"/>
                        <group invisible="lug_hr_employee_edit_policy != 'zones'">
                            <field name="lug_hr_employee_edit_mien_zone_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <div class="text-muted" colspan="2">
                                Chỉ giới hạn thao tác <b>sửa/tạo hồ sơ nhân viên</b>.
                                Không ảnh hưởng quyền xem, nghỉ phép, chấm công, menu.
                            </div>
                        </group>
                    </group>
                    <separator string="Quyền bổ sung riêng"/>
                    <div class="text-muted mb-2">
                        Quyền hiệu lực = Nhóm quyền + Quyền bổ sung riêng.
                        Chỉ xem HR → ẩn menu Học hỏi, Báo cáo, Phòng ban.
                        Không có quyền Thảo luận → ẩn biểu tượng thông báo trên thanh menu.
                    </div>
                    <field name="lug_user_permission_ids" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
