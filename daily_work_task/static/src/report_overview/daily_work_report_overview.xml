                                                                            <t t-esc="row.overdue_label"/>
                                                                        </span>
                                                                    </t>
                                                                </td>
                                                            </tr>
                                                        </t>
                                                    </t>
                                                </t>
                                                <tr class="o_dro_excel_total" t-if="excelGroups.length">
                                                    <td colspan="11">
                                                        Tổng % hoàn thành công việc trong tháng
                                                        (AVERAGE các hạng mục):
                                                        <strong t-esc="formatMonthAvg()"/>%
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            </t>
                        </t>
