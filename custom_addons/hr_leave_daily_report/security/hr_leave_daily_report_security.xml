<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
    Permission "Ngày nghỉ theo ngày" shown under Settings > Users > Nhân sự.
    Lets an admin grant a user visibility on the daily leave report (hr.leave.daily.report),
    scoped to a Miền:
      - "VP": the user only sees VP daily leave records.
      - "Bắc/Nam/ĐTT": the user sees Bắc, Nam and ĐTT daily leave records.
    HR/Time Off managers keep full visibility; everyone else sees nothing unless granted.
    -->
    <record id="res_groups_privilege_daily_report_mien" model="res.groups.privilege">
        <field name="name">Ngày nghỉ theo ngày</field>
        <field name="sequence">16</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="description">Controls which Miền the user can see in the "Ngày nghỉ theo ngày" report. Without this permission the user does not see any daily leave record.</field>
        <field name="placeholder">Không</field>
    </record>

    <record id="group_daily_report_mien_vp" model="res.groups">
        <field name="name">VP</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_daily_report_mien"/>
        <field name="implied_ids" eval="[(4, ref('hr_holidays.group_hr_holidays_responsible'))]"/>
        <field name="comment">The user can view "Ngày nghỉ theo ngày" records of Miền VP only.</field>
    </record>

    <record id="group_daily_report_mien_bnd" model="res.groups">
        <field name="name">Bắc/Nam/ĐTT</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_daily_report_mien"/>
        <field name="implied_ids" eval="[(4, ref('hr_holidays.group_hr_holidays_responsible'))]"/>
        <field name="comment">The user can view "Ngày nghỉ theo ngày" records of Miền Bắc, Nam and ĐTT.</field>
    </record>

    <!--
    Global record rule: applies to every reader of hr.leave.daily.report.
    HR managers and Time Off administrators keep full access; all other users
    are limited to the Miền granted through the privilege above. Records with no
    Miền are only visible to managers.
    -->
    <record id="hr_leave_daily_report_mien_rule" model="ir.rule">
        <field name="name">Ngày nghỉ theo ngày: lọc theo Miền</field>
        <field name="model_id" ref="model_hr_leave_daily_report"/>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[(1, '=', 1)] if (user.has_group('hr.group_hr_manager') or user.has_group('hr_holidays.group_hr_holidays_manager')) else ([('employee_leave_mien', 'in', ['VP', 'Bắc', 'Nam', 'ĐTT'])] if (user.has_group('hr_leave_daily_report.group_daily_report_mien_vp') and user.has_group('hr_leave_daily_report.group_daily_report_mien_bnd')) else ([('employee_leave_mien', '=', 'VP')] if user.has_group('hr_leave_daily_report.group_daily_report_mien_vp') else ([('employee_leave_mien', 'in', ['Bắc', 'Nam', 'ĐTT'])] if user.has_group('hr_leave_daily_report.group_daily_report_mien_bnd') else [(0, '=', 1)])))</field>
    </record>
</odoo>
