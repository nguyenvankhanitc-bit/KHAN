<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- P1/P2/O: list view chỉ hiển thị ngày, không hiển thị giờ -->
    <record id="hr_leave_view_tree_p1_p2_o_date_display" model="ir.ui.view">
        <field name="name">hr.leave.list.p1.p2.o.date.display</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_from']" position="replace">
                <field name="date_from" column_invisible="1"/>
                <field name="leave_list_date_from_display"/>
            </xpath>
            <xpath expr="//field[@name='date_to']" position="replace">
                <field name="date_to" column_invisible="1"/>
                <field name="leave_list_date_to_display"/>
            </xpath>
        </field>
    </record>

    <record id="hr_leave_view_form_mien_filter" model="ir.ui.view">
        <field name="name">hr.leave.form.mien.filter</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id'][@invisible='1']" position="after">
                <field name="mien_allowed_leave_type_ids" invisible="1"/>
                <field name="holiday_status_id_month_leave_type_locked" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='holiday_status_id'][@force_save='1']" position="attributes">
                <attribute name="domain">[('id', 'in', mien_allowed_leave_type_ids)]</attribute>
                <attribute name="readonly">state in ['cancel', 'refuse', 'validate', 'validate1'] or holiday_status_id_month_leave_type_locked</attribute>
                <attribute name="context">{
                    'employee_id': employee_id,
                    'default_employee_id': employee_id,
                    'default_date_from': date_from,
                    'default_date_to': date_to,
                    'filter_leave_types_by_employee_mien': True
                }</attribute>
            </xpath>
            <xpath expr="//field[@name='holiday_status_id'][@force_save='1']" position="after">
                <field
                    name="monthly_leave_split_preview"
                    colspan="2"
                    readonly="1"
                    force_save="1"
                    invisible="not monthly_leave_split_preview"
                    widget="text"
                />
            </xpath>
        </field>
    </record>
</odoo>
