<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_dashboard_department" model="ir.ui.view">
        <field name="name">hr.leave.view.form.dashboard.department</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_dashboard"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='col_left']/field[@name='employee_id'][@widget='many2one_avatar_employee']" position="replace">
                <label for="employee_id" string="Nhân viên"/>
                <div class="o_hr_leave_employee_row">
                    <field
                        name="employee_id"
                        widget="many2one_avatar_employee"
                        readonly="1"
                        nolabel="1"
                        class="flex-grow-1"
                    />
                    <field
                        name="employee_id_hrm"
                        readonly="1"
                        nolabel="1"
                        class="text-muted o_hr_leave_employee_id_hrm"
                    />
                </div>
                <field name="employee_ma_bo_phan" readonly="1"/>
                <field name="department_id" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='name'][@widget='text']" position="attributes">
                <attribute name="nolabel" remove="nolabel"/>
                <attribute name="string">Lý do</attribute>
                <attribute name="placeholder">Nhập lý do nghỉ phép...</attribute>
            </xpath>
            <xpath expr="//field[@name='supported_attachment_ids'][@widget='many2many_binary']" position="before">
                <div class="alert alert-secondary mb-2" colspan="2" invisible="state != 'confirm'">
                    <span>Bắt buộc đính kèm file </span>
                    <strong>Đơn xin nghỉ phép</strong>
                    <span> (tải mẫu </span>
                    <a href="/hr_leave/download_leave_form_template">tại đây</a>
                    <span>).</span>
                </div>
            </xpath>
        </field>
    </record>

    <!-- time-off-overview (Tổng quan) uses hr.leave.report.calendar + this form -->
    <record id="hr_leave_report_calendar_view_form_department" model="ir.ui.view">
        <field name="name">hr.leave.report.calendar.view.form.department</field>
        <field name="model">hr.leave.report.calendar</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_report_calendar_view_form"/>
        <field name="arch" type="xml">
            <field name="employee_id" position="replace">
                <label for="employee_id" string="Nhân viên"/>
                <div class="o_hr_leave_employee_row">
                    <field
                        name="employee_id"
                        widget="many2one_avatar_employee"
                        readonly="1"
                        nolabel="1"
                        class="flex-grow-1"
                    />
                    <field
                        name="employee_id_hrm"
                        readonly="1"
                        nolabel="1"
                        class="text-muted o_hr_leave_employee_id_hrm"
                    />
                </div>
                <field name="employee_ma_bo_phan" readonly="1"/>
                <field name="department_id" readonly="1"/>
            </field>
            <field name="description" position="replace">
                <field
                    name="leave_reason"
                    readonly="1"
                    widget="text"
                    placeholder="Không có lý do nào"
                />
            </field>
        </field>
    </record>
</odoo>
