<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_task_performance_access_list" model="ir.ui.view">
        <field name="name">daily.task.performance.access.list</field>
        <field name="model">daily.task.performance.access</field>
        <field name="arch" type="xml">
            <list string="Phân quyền Báo cáo hiệu suất" editable="bottom">
                <field name="employee_id"
                         string="User được xem"
                         options="{'no_create': True}"/>
                <field name="department_ids"
                         string="Phòng ban được xem"
                         widget="many2many_tags"
                         options="{'no_create': True}"/>
                <field name="target_ids"
                         string="User bị xem"
                         widget="many2many_tags"
                         options="{'no_create': True}"/>
                <field name="user_id" optional="hide" readonly="1"/>
                <field name="note" optional="hide"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_daily_task_performance_access_form" model="ir.ui.view">
        <field name="name">daily.task.performance.access.form</field>
        <field name="model">daily.task.performance.access</field>
        <field name="arch" type="xml">
            <form string="Phân quyền Báo cáo hiệu suất">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <b>Cách phân quyền:</b><br/>
                        1. Chọn <b>Phòng ban được xem</b> (một hoặc nhiều) → tự lấy tất cả NV trong phòng, không cần chọn User bị xem.<br/>
                        2. Nếu <b>Phòng ban trống</b> → bắt buộc chọn <b>User bị xem</b> (có thể chọn nhiều).
                    </div>
                    <group>
                        <group string="Người được quyền">
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group string="Ghi chú">
                            <field name="note"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <group string="Phòng ban được xem">
                            <field name="department_ids" widget="many2many_tags" nolabel="1"
                                     options="{'no_create': True}"/>
                        </group>
                        <group string="User bị xem (bắt buộc nếu không chọn phòng ban)">
                            <field name="target_ids" widget="many2many_tags" nolabel="1"
                                     options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_daily_task_performance_access" model="ir.actions.act_window">
        <field name="name">Phân quyền Báo cáo hiệu suất</field>
        <field name="res_model">daily.task.performance.access</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chọn phòng ban (ăn theo toàn bộ NV) hoặc chọn từng User bị xem khi không chọn phòng ban.
            </p>
        </field>
    </record>

    <record id="action_daily_work_performance_report" model="ir.actions.client">
        <field name="name">Báo cáo hiệu suất</field>
        <field name="tag">daily_work_performance_report</field>
    </record>
</odoo>
