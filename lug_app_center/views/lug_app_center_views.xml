<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_lug_app_center" model="ir.actions.client">
        <field name="name">Enterprise Application Center</field>
        <field name="tag">lug_app_center</field>
        <field name="path">app-center</field>
        <field name="target">current</field>
    </record>

    <record id="action_lug_app_announcement" model="ir.actions.act_window">
        <field name="name">Thông báo nội bộ</field>
        <field name="res_model">lug.app.announcement</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_lug_app_announcement_list" model="ir.ui.view">
        <field name="name">lug.app.announcement.list</field>
        <field name="model">lug.app.announcement</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="announce_date"/>
                <field name="tag"/>
                <field name="tag_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lug_app_announcement_form" model="ir.ui.view">
        <field name="name">lug.app.announcement.form</field>
        <field name="model">lug.app.announcement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="announce_date"/>
                        <field name="tag"/>
                        <field name="tag_type"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="body" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
