<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Mở đúng dashboard nghỉ phép (Spreadsheet) — giao diện giống Báo cáo tổng quan Odoo -->
    <record id="action_hr_leave_analytics_spreadsheet_dashboard" model="ir.actions.client">
        <field name="name">Báo cáo tổng</field>
        <field name="tag">action_spreadsheet_dashboard</field>
        <field name="params" eval="{'dashboard_id': ref('spreadsheet_dashboard_leave')}"/>
    </record>

    <!-- Menu gốc: Ngày nghỉ → Báo cáo → Báo cáo tổng (mở thẳng dashboard) -->
    <menuitem
        id="menu_hr_leave_analytics_root"
        name="Báo cáo tổng"
        parent="hr_holidays.menu_hr_holidays_report"
        action="action_hr_leave_analytics_spreadsheet_dashboard"
        sequence="0"
        groups="hr_holidays.group_hr_holidays_user"
    />

    <menuitem
        id="menu_hr_leave_analytics_dashboard"
        name="Tổng quan"
        parent="menu_hr_leave_analytics_root"
        action="action_hr_leave_analytics_spreadsheet_dashboard"
        sequence="1"
    />

    <menuitem
        id="menu_hr_leave_analytics_by_type"
        name="Theo loại nghỉ"
        parent="menu_hr_leave_analytics_root"
        action="action_hr_leave_analytics_by_type"
        sequence="2"
    />

    <menuitem
        id="menu_hr_leave_analytics_by_department"
        name="Theo phòng ban"
        parent="menu_hr_leave_analytics_root"
        action="action_hr_leave_analytics_by_department"
        sequence="3"
    />

    <menuitem
        id="menu_hr_leave_analytics_by_mien"
        name="Theo miền"
        parent="menu_hr_leave_analytics_root"
        action="action_hr_leave_analytics_by_mien"
        sequence="4"
    />

    <menuitem
        id="menu_hr_leave_analytics_by_store"
        name="Theo cửa hàng"
        parent="menu_hr_leave_analytics_root"
        action="action_hr_leave_analytics_by_store"
        sequence="5"
    />

    <menuitem
        id="menu_hr_leave_analytics_trend"
        name="Xu hướng"
        parent="menu_hr_leave_analytics_root"
        action="action_hr_leave_analytics_trend"
        sequence="6"
    />

    <menuitem
        id="menu_hr_leave_analytics_detail"
        name="Chi tiết"
        parent="menu_hr_leave_analytics_root"
        action="action_hr_leave_analytics_report"
        sequence="7"
    />

    <!-- Gắn mặc định cho menu Báo cáo: click vào Báo cáo cũng mở Báo cáo tổng nghỉ phép -->
    <record id="hr_holidays.menu_hr_holidays_report" model="ir.ui.menu">
        <field name="action" ref="action_hr_leave_analytics_spreadsheet_dashboard"/>
    </record>
</odoo>
