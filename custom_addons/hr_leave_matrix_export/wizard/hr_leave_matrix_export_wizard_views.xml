<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_leave_matrix_export_wizard_form" model="ir.ui.view">
        <field name="name">hr.leave.matrix.export.wizard.form</field>
        <field name="model">hr.leave.matrix.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export time off matrix">
                <p class="text-muted">
                    Xuất bảng ma trận ngày nghỉ nhân viên miền VP.
                </p>
                <group>
                    <field name="year"/>
                    <field name="month"/>
                </group>
                <field name="domain_json" invisible="1"/>
                <footer>
                    <button name="action_export_matrix_excel" type="object" string="Export Excel" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
