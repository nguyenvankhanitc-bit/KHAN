<?xml version="1.0"?>
<odoo>
<data>
    <record id="checklist_stage_view_form" model="ir.ui.view">
        <field name="name">checklist.stage.view.form</field>
        <field name="model">checklist.stage</field>
        <field name="arch" type="xml">
            <form string="Checklist Stage">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder='e.g. "In Progress"'/>
                            <field name="pipe_end"/>
                        </group>
                        <group>
                            <field name="fold"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group string="Add a description that will appear as a tooltip for this stage">
                        <field name="description" placeholder="Add a description..." nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="checklist_stage_view_tree" model="ir.ui.view">
        <field name="name">checklist.stage.view.list</field>
        <field name="model">checklist.stage</field>
        <field name="arch" type="xml">
            <list string="Checklist Stages">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="checklist_stage_action" model="ir.actions.act_window">
        <field name="name">Checklist Stages</field>
        <field name="res_model">checklist.stage</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Checklist Stage
            </p><p>
                Checklist stages are used to track the progress of a checklist from start to conclusion.
            </p>
        </field>
    </record>

    <record id="checklist_stage_menu" model="ir.ui.menu">
        <field name="action" ref="hr_employee_checklist.checklist_stage_action"/>
    </record>

</data>
</odoo>
