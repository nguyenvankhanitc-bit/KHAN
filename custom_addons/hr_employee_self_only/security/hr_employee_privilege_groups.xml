<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="res.groups.privilege" id="res_groups_privilege_employee_edit">
        <field name="name">Edit Employee Profile</field>
        <field name="sequence">13</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="description">Controls whether the user can create or edit employee records.</field>
        <field name="placeholder">Không</field>
    </record>

    <record id="group_hr_employee_edit_allowed" model="res.groups">
        <field name="name">Allowed</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_employee_edit"/>
        <field name="comment">The user can create and edit employee records within their access scope.</field>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_view_personal">
        <field name="name">View Personal Information</field>
        <field name="sequence">14</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="description">Controls whether the user can see the Personal tab on employee profiles.</field>
        <field name="placeholder">Không</field>
    </record>

    <record id="group_hr_employee_view_personal_allowed" model="res.groups">
        <field name="name">Allowed</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_view_personal"/>
        <field name="comment">The user can open the Personal tab on employee profiles within their access scope.</field>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
