<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Hotfix: prevent AccessError in Time Off popup flows that trigger a write on hr.leave.type.
      Keep scope narrow: allow write for Time Off Officers only (no create/delete).
    -->
    <record id="access_hr_leave_type_officer_write_hotfix" model="ir.model.access">
        <field name="name">time_off_extra_approval.hr.leave.type.officer.write.hotfix</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_type"/>
        <field name="group_id" ref="hr_holidays.group_hr_holidays_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>
