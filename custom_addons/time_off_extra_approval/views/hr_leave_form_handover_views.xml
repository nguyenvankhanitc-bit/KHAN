<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_handover_recipients" model="ir.ui.view">
        <field name="name">hr.leave.form.handover.recipients</field>
        <field name="model">hr.leave</field>
        <field name="priority">90</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='holiday_status_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_open': True, 'request_type': 'leave'}</attribute>
            </xpath>
            <xpath expr="//header" position="inside">
                <field name="can_respond_handover" invisible="1"/>
                <field name="can_manage_handover_replacement" invisible="1"/>
                <button
                    name="action_handover_accept"
                    string="Accept work handover"
                    type="object"
                    class="btn-primary"
                    data-hotkey="y"
                    invisible="not can_respond_handover or not id"
                />
                <button
                    name="action_handover_refuse"
                    string="Refuse work handover"
                    type="object"
                    class="btn-secondary"
                    data-hotkey="n"
                    invisible="not can_respond_handover or not id"
                />
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_emergency_leave" invisible="1"/>
                <field name="can_skip_work_handover" invisible="1"/>
                <div
                    class="alert alert-warning"
                    role="status"
                    invisible="not is_emergency_leave"
                >
                    This request is recorded as emergency leave (insufficient advance notice).
                </div>
                <field name="handover_escalation_pick_prompt" invisible="1"/>
                <field name="handover_assigned_recipient_banner" invisible="1"/>
                <field name="handover_recipient_list_readonly" invisible="1"/>
                <field name="handover_sheet_hidden_for_viewer" invisible="1"/>
                <div
                    class="alert alert-info"
                    role="status"
                    invisible="state not in ('confirm', 'validate1') or not handover_assigned_recipient_banner"
                >
                    <field name="handover_assigned_recipient_banner" readonly="1" nolabel="1"/>
                </div>
                <div
                    class="alert alert-warning"
                    role="alert"
                    invisible="state not in ('confirm', 'validate1') or not handover_escalation_pick_prompt"
                >
                    <field name="handover_escalation_pick_prompt" readonly="1" nolabel="1"/>
                </div>
                <field name="handover_employee_ids" invisible="1"/>
                <field
                    name="handover_acceptance_ids"
                    string="Work Handover To"
                    invisible="can_manage_handover_replacement or can_respond_handover or skip_work_handover or handover_sheet_hidden_for_viewer"
                    readonly="state not in ('draft', 'confirm') or handover_recipient_list_readonly or can_manage_handover_replacement"
                >
                    <list editable="bottom" create="1" delete="1">
                        <field name="sequence" string="STT" readonly="1"/>
                        <field
                            name="employee_id"
                            options="{'no_create': True, 'no_open': True}"
                            domain="[('id', '!=', parent.employee_id), ('user_id', '!=', False), ('id', 'not in', parent.unavailable_handover_employee_ids)]"
                        />
                        <field name="handover_work_content" string="Nội dung công việc"/>
                    </list>
                </field>
                <field
                    name="skip_work_handover"
                    string="Không cần bàn giao công việc"
                    readonly="state not in ('draft', 'confirm')"
                />
                <field name="unavailable_handover_employee_ids" invisible="1"/>
                <field name="handover_replacement_picker_open" invisible="1"/>
                <field name="handover_refused_recipient_ids" invisible="1"/>
                <field name="handover_replaceable_recipient_ids" invisible="1"/>
                <field name="handover_escalation_label" invisible="1"/>
                <div
                    class="alert alert-info"
                    role="status"
                    invisible="state not in ('confirm', 'validate1') or not handover_escalation_label"
                >
                    <field name="handover_escalation_label" readonly="1" nolabel="1"/>
                </div>
                <div
                    class="alert alert-light border"
                    role="status"
                    invisible="state not in ('confirm', 'validate1') or not handover_waiting_label"
                >
                    <field name="handover_waiting_label" readonly="1" nolabel="1"/>
                </div>
            </xpath>
            <!-- Full sheet width (direct child of sheet, after the two-column block). -->
            <xpath expr="//sheet" position="inside">
                <div
                    class="row g-0 mt-2 o_handover_replacement_fullwidth w-100 align-self-stretch"
                    invisible="not can_manage_handover_replacement"
                >
                    <div class="col-12 px-0">
                        <div class="alert alert-warning mb-0" role="alert">
                            <field name="handover_refused_label" readonly="1" nolabel="1"/>
                            <div class="mt-1">Choose another colleague to receive work handover.</div>
                            <div class="mt-2" invisible="handover_replacement_picker_open">
                                <button
                                    name="action_handover_replacement_yes"
                                    string="Yes"
                                    type="object"
                                    class="btn-primary me-2"
                                />
                                <button
                                    name="action_handover_replacement_no"
                                    string="No"
                                    type="object"
                                    class="btn-secondary"
                                />
                            </div>
                            <div class="mt-2" invisible="not handover_replacement_picker_open">
                                <field
                                    name="handover_replacement_draft_ids"
                                    readonly="not can_manage_handover_replacement"
                                >
                                    <list editable="bottom" create="1" delete="1">
                                        <field name="sequence" string="STT" readonly="1"/>
                                        <field
                                            name="replace_employee_id"
                                            string="Cần thay"
                                            domain="[('id', 'in', parent.handover_replaceable_recipient_ids)]"
                                            options="{'no_create': True, 'no_open': True}"
                                        />
                                        <field
                                            name="new_employee_id"
                                            string="Người nhận"
                                            domain="[('id', 'in', allowed_new_employee_ids)]"
                                            options="{'no_create': True, 'no_open': True}"
                                        />
                                        <field name="allowed_new_employee_ids" column_invisible="1"/>
                                        <field name="handover_work_content" string="Nội dung"/>
                                    </list>
                                </field>
                                <div class="mt-2">
                                    <button
                                        name="action_handover_apply_replacement"
                                        string="Apply"
                                        type="object"
                                        class="btn-primary me-2"
                                    />
                                    <button
                                        name="action_handover_replacement_no"
                                        string="Cancel"
                                        type="object"
                                        class="btn-secondary"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
            <!-- Right column (beside main fields): refusal reasons visible to anyone who can open the form -->
            <xpath expr="//div[hasclass('col_right')]" position="inside">
                <div
                    class="alert alert-light border mb-2"
                    role="status"
                    invisible="state not in ('confirm', 'validate1') or not handover_refusal_reason_label"
                >
                    <field
                        name="handover_refusal_reason_label"
                        string="Work handover refusal details"
                        readonly="1"
                        widget="text"
                    />
                </div>
            </xpath>
        </field>
    </record>

    <!-- Calendar / Time Off popup hides the form header; put handover actions in the sheet. -->
    <record id="hr_leave_view_form_dashboard_handover_actions" model="ir.ui.view">
        <field name="name">hr.leave.dashboard.form.handover.actions</field>
        <field name="model">hr.leave</field>
        <field name="priority">90</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_dashboard_new_time_off"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='holiday_status_id']" position="attributes">
                <!-- In dashboard popup, existing requests should not mutate leave type (avoids access errors on hr.leave.type). -->
                <attribute name="readonly">id</attribute>
                <attribute name="options">{'no_create': True, 'no_open': True, 'no_create_edit': True, 'request_type': 'leave'}</attribute>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <field name="is_emergency_leave" invisible="1"/>
                <div
                    class="alert alert-warning mb-2"
                    role="status"
                    invisible="not is_emergency_leave"
                >
                    This request is recorded as emergency leave (insufficient advance notice).
                </div>
                <field name="can_respond_handover" invisible="1"/>
                <field name="handover_escalation_pick_prompt" invisible="1"/>
                <field name="handover_assigned_recipient_banner" invisible="1"/>
                <field name="handover_recipient_list_readonly" invisible="1"/>
                <field name="handover_waiting_label" invisible="1"/>
                <field name="handover_refused_label" invisible="1"/>
                <field name="handover_replacement_picker_open" invisible="1"/>
                <field name="handover_refused_recipient_ids" invisible="1"/>
                <field name="handover_replaceable_recipient_ids" invisible="1"/>
                <field name="handover_escalation_label" invisible="1"/>
                <field name="can_manage_handover_replacement" invisible="1"/>
                <div
                    class="alert alert-info mb-2"
                    role="status"
                    invisible="not id or state not in ('confirm', 'validate1') or not handover_assigned_recipient_banner"
                >
                    <field name="handover_assigned_recipient_banner" readonly="1" nolabel="1"/>
                </div>
                <div
                    class="alert alert-warning mb-2"
                    role="alert"
                    invisible="not id or not handover_escalation_pick_prompt"
                >
                    <field name="handover_escalation_pick_prompt" readonly="1" nolabel="1"/>
                </div>
                <div
                    class="alert alert-warning mb-2"
                    role="alert"
                    invisible="not id or not handover_waiting_label"
                >
                    <field name="handover_waiting_label" readonly="1" nolabel="1"/>
                </div>
                <div
                    class="alert alert-light border mb-2"
                    role="status"
                    invisible="not id or state not in ('confirm', 'validate1') or not handover_refusal_reason_label"
                >
                    <field
                        name="handover_refusal_reason_label"
                        string="Work handover refusal details"
                        readonly="1"
                        widget="text"
                    />
                </div>
                <div
                    class="alert alert-info mb-2"
                    role="status"
                    invisible="not id or state not in ('confirm', 'validate1') or not handover_escalation_label"
                >
                    <field name="handover_escalation_label" readonly="1" nolabel="1"/>
                </div>
                <div
                    class="alert alert-info mb-2"
                    role="alert"
                    invisible="not id or not can_respond_handover"
                >
                    <p class="mb-2">
                        You were selected for work handover for this request. Please accept or refuse.
                    </p>
                    <button
                        name="action_handover_accept"
                        string="Accept work handover"
                        type="object"
                        class="btn btn-primary me-2"
                        data-hotkey="y"
                        invisible="not can_respond_handover"
                    />
                    <button
                        name="action_handover_refuse"
                        string="Refuse work handover"
                        type="object"
                        class="btn btn-secondary"
                        data-hotkey="n"
                        invisible="not can_respond_handover"
                    />
                </div>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <div
                    class="row g-0 mt-2 o_handover_replacement_fullwidth w-100 align-self-stretch"
                    invisible="not id or not can_manage_handover_replacement"
                >
                    <div class="col-12 px-0">
                        <div class="alert alert-warning mb-0" role="alert">
                            <field name="handover_refused_label" readonly="1" nolabel="1"/>
                            <div class="mt-1">Choose another colleague to receive work handover.</div>
                            <div class="mt-2" invisible="handover_replacement_picker_open">
                                <button
                                    name="action_handover_replacement_yes"
                                    string="Yes"
                                    type="object"
                                    class="btn btn-primary me-2"
                                />
                                <button
                                    name="action_handover_replacement_no"
                                    string="No"
                                    type="object"
                                    class="btn btn-secondary"
                                />
                            </div>
                            <div class="mt-2" invisible="not handover_replacement_picker_open">
                                <field
                                    name="handover_replacement_draft_ids"
                                    readonly="not can_manage_handover_replacement"
                                >
                                    <list editable="bottom" create="1" delete="1">
                                        <field name="sequence" string="STT" readonly="1"/>
                                        <field
                                            name="replace_employee_id"
                                            string="Cần thay"
                                            domain="[('id', 'in', parent.handover_replaceable_recipient_ids)]"
                                            options="{'no_create': True, 'no_open': True}"
                                        />
                                        <field
                                            name="new_employee_id"
                                            string="Người nhận"
                                            domain="[('id', 'in', allowed_new_employee_ids)]"
                                            options="{'no_create': True, 'no_open': True}"
                                        />
                                        <field name="allowed_new_employee_ids" column_invisible="1"/>
                                        <field name="handover_work_content" string="Nội dung"/>
                                    </list>
                                </field>
                                <div class="mt-2">
                                    <button
                                        name="action_handover_apply_replacement"
                                        string="Apply"
                                        type="object"
                                        class="btn btn-primary me-2"
                                    />
                                    <button
                                        name="action_handover_replacement_no"
                                        string="Cancel"
                                        type="object"
                                        class="btn btn-secondary"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
