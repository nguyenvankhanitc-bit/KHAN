<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_leave_analytics.LeaveAnalyticsDashboard">
        <div class="o_leave_analytics_dashboard o_action">
            <div class="o_leave_analytics_header d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h1 t-esc="state.data ? state.data.title : 'Báo cáo nghỉ phép'"/>
                    <p class="text-muted mb-0">Dữ liệu tháng hiện tại — Sáng Tâm</p>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="text-center p-5"><i class="fa fa-spinner fa-spin fa-2x"/></div>
            </t>

            <t t-elif="state.data">
                <!-- Biểu đồ: tổng quan = 4 miền, dashboard theo miền = chỉ 1 miền -->
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span t-esc="state.data.mien_chart_title"/>
                        <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.openList('mien_compare')">
                            <i class="fa fa-table me-1"/>Xem bảng / Xuất Excel
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-7">
                                <div class="o_mien_pie_section">
                                    <div class="o_mien_pie_chart_wrap">
                                        <canvas t-ref="mienPieChart"/>
                                    </div>
                                    <div class="o_mien_pie_legend">
                                        <t t-foreach="state.data.mien_comparison" t-as="item" t-key="item.mien">
                                            <div class="o_mien_legend_item">
                                                <span class="o_mien_legend_dot" t-att-style="'background-color: ' + getMienColor(item.mien)"/>
                                                <span class="o_mien_legend_label" t-esc="item.label"/>
                                                <span class="o_mien_legend_value">
                                                    <t t-esc="item.leave_days"/> ngày
                                                </span>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <p t-if="!mienTotalDays" class="text-muted text-center mb-0 mt-2">
                                    Chưa có ngày nghỉ trong tháng này
                                </p>
                            </div>
                            <div class="col-lg-5">
                                <table class="table table-sm table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th>Miền</th>
                                            <th class="text-end">Ngày nghỉ</th>
                                            <th class="text-end">Tỷ lệ (%)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.data.mien_comparison" t-as="item" t-key="item.mien + '_rate'">
                                            <tr>
                                                <td t-esc="item.label"/>
                                                <td class="text-end" t-esc="item.leave_days"/>
                                                <td class="text-end" t-esc="item.leave_rate"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <!-- 3. Top nhân viên cần chú ý -->
                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span>Top nhân viên cần chú ý</span>
                                <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.openList('watch_employees')">
                                    <i class="fa fa-file-excel-o me-1"/>Xuất Excel
                                </button>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0 o_excel_table">
                                    <thead>
                                        <tr>
                                            <th>Nhân viên</th>
                                            <th>Cửa hàng</th>
                                            <th>Chức danh</th>
                                            <th class="text-end">Số ngày</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.data.watch_employees" t-as="row" t-key="row.employee_id">
                                            <tr class="cursor-pointer" t-on-click="() => this.drillDown('employee', row.employee_id)">
                                                <td t-esc="row.employee_name"/>
                                                <td t-esc="row.store_name"/>
                                                <td t-esc="row.job_title"/>
                                                <td class="text-end" t-esc="row.leave_days"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- 4. Top cửa hàng nghỉ nhiều nhất -->
                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span>Top cửa hàng nghỉ nhiều nhất</span>
                                <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.openList('top_stores')">
                                    <i class="fa fa-file-excel-o me-1"/>Xuất Excel
                                </button>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0 o_excel_table">
                                    <thead>
                                        <tr>
                                            <th>Cửa hàng</th>
                                            <th>Chức danh</th>
                                            <th class="text-end">Tổng NV</th>
                                            <th class="text-end">Ngày nghỉ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.data.top_stores" t-as="row" t-key="row.store_id">
                                            <tr class="cursor-pointer" t-on-click="() => this.drillDown('store', row.store_id)">
                                                <td t-esc="row.store_name"/>
                                                <td t-esc="row.job_title"/>
                                                <td class="text-end" t-esc="row.employee_count"/>
                                                <td class="text-end" t-esc="row.leave_days"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 5. Danh sách cảnh báo -->
                <div class="card mt-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Danh sách cảnh báo cửa hàng</span>
                        <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.openList('store_alerts')">
                            <i class="fa fa-file-excel-o me-1"/>Xuất Excel
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0 o_excel_table">
                            <thead>
                                <tr>
                                    <th>Cửa hàng</th>
                                    <th>Chức danh</th>
                                    <th class="text-end">Tổng NV</th>
                                    <th class="text-end">Đang nghỉ</th>
                                    <th class="text-end">Tỷ lệ (%)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.data.store_alerts" t-as="row" t-key="row.store_id">
                                    <tr class="cursor-pointer" t-on-click="() => this.drillDown('store', row.store_id)">
                                        <td t-esc="row.store_name"/>
                                        <td t-esc="row.job_title"/>
                                        <td class="text-end" t-esc="row.employee_count"/>
                                        <td class="text-end" t-esc="row.on_leave_today"/>
                                        <td class="text-end">
                                            <span t-att-class="row.on_leave_rate >= 30 ? 'text-danger fw-bold' : ''" t-esc="row.on_leave_rate"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
