<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_task_send_overdue_form" model="ir.ui.view">
        <field name="name">daily.task.send.overdue.mail.form</field>
        <field name="model">daily.task.send.overdue.mail</field>
        <field name="arch" type="xml">
            <form string="Gửi mail giục quá hạn">
                <group>
                    <field name="assignee_id" options="{'no_create': True}"/>
                    <field name="overdue_count" readonly="1"/>
                    <field name="employee_count" readonly="1"/>
                </group>
                <field name="preview_html" nolabel="1" colspan="2"/>
                <footer>
                    <button name="action_send" type="object" string="Gửi mail" class="btn-danger"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_daily_task_send_overdue" model="ir.actions.act_window">
        <field name="name">Gửi mail giục quá hạn</field>
        <field name="res_model">daily.task.send.overdue.mail</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
